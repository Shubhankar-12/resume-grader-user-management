# ===========================================
# ResumeRocket Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Server
PORT=8010
REPO_BASE_URL=http://localhost:8010
FRONTEND_URL=http://localhost:3000

# MongoDB
DB_URI=mongodb://127.0.0.1:27017/resume-grader

# Redis
REDIS_URL=redis://localhost:6379

# JWT secrets (use strong random values in production)
OWNER_POLICY_JWT_KEY=
ADMIN_POLICY_JWT_KEY=
CUSTOMER_POLICY_JWT_KEY=
PASSWORD_SECRET_KEY=

# AWS S3
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
REGION=
AWS_BUCKET_NAME=
BUCKET_PROXY_URL=
IMAGE_PROXY_URL=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# AI Model Routing (per-task, optional — defaults shown)
# Supported models: gpt-4o, gpt-4o-mini, claude-sonnet-4-6, gemini-2.5-pro, gemini-2.0-flash
AI_MODEL_GRADING=gpt-4o
AI_MODEL_EXTRACTION=gpt-4o-mini
AI_MODEL_REPORT=gpt-4o
AI_MODEL_TAILORING=gpt-4o
AI_MODEL_JOB_MATCH=gpt-4o-mini
AI_MODEL_COVER_LETTER=gpt-4o-mini
AI_MODEL_PROJECT_ANALYSIS=gpt-4o-mini

# AI Integration Tests (set to true to run real API tests — costs money)
RUN_AI_TESTS=false

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Razorpay payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Sentry error tracking
SENTRY_DSN=

# Logging
LOG_IN_DB=true
LOG_IN_FILE=true
